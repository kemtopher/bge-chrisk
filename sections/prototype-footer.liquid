{{ 'prototype-footer.css' | asset_url | stylesheet_tag }}

<div id="prototype-footer" class="prototype-footer">
  <div class="prototype-footer__card">
    <div class="prototype-footer__top">
      <div class="prototype-footer__signup">
        <a href="{{ routes.root_url }}" class="prototype-footer__logo">Big Green Egg</a>

        <p class="prototype-footer__intro">
          Subscribe to get tasty recipes, insider news, special offers, and more.
        </p>

        <div class="prototype-footer__form">
          <div class="prototype-footer__input-wrap">
            <input
              type="email"
              placeholder="Email"
              aria-label="Email address"
              class="prototype-footer__input"
            >
          </div>

          <button type="button" class="prototype-footer__button">
            Subscribe
          </button>
        </div>

        <div class="prototype-footer__socials" aria-label="Social links">
          <a href="#" aria-label="Instagram" class="prototype-footer__social">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1"></circle>
            </svg>
          </a>

          <a href="#" aria-label="Facebook" class="prototype-footer__social">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13.5 20v-7h2.5l.5-3h-3V8.3c0-.9.3-1.6 1.7-1.6H16V4.1c-.3 0-.9-.1-1.8-.1-2.8 0-4.2 1.5-4.2 4.2V10H7.5v3H10v7"></path>
            </svg>
          </a>

          <a href="#" aria-label="X" class="prototype-footer__social">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 4l16 16"></path>
              <path d="M20 4L4 20"></path>
            </svg>
          </a>

          <a href="#" aria-label="Pinterest" class="prototype-footer__social">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="8.5"></circle>
              <path d="M10.5 20l1.2-4.4"></path>
              <path d="M10.5 13.5c-.5-.7-.8-1.5-.8-2.4 0-2 1.5-3.7 3.9-3.7 2.1 0 3.4 1.4 3.4 3.1 0 2.4-1.1 4.3-2.8 4.3-.9 0-1.5-.7-1.3-1.6l.5-2.1"></path>
            </svg>
          </a>

          <a href="#" aria-label="YouTube" class="prototype-footer__social">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3.5" y="6.5" width="17" height="11" rx="3"></rect>
              <path d="M10 9.5l5 2.5-5 2.5z"></path>
            </svg>
          </a>

          <a href="#" aria-label="RSS" class="prototype-footer__social">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="6.5" cy="17.5" r="1.2"></circle>
              <path d="M5.5 11.5a7 7 0 0 1 7 7"></path>
              <path d="M5.5 6.5c5.8 0 10.5 4.7 10.5 10.5"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="prototype-footer__menus">
        <div class="prototype-footer__menu">
          <h3>Support</h3>
          <ul>
            <li><a href="#">Getting Started</a></li>
            <li><a href="#">Compare Egg Sizes</a></li>
            <li><a href="#">Shipping &amp; Delivery</a></li>
            <li><a href="#">Returns &amp; Exchanges</a></li>
            <li><a href="#">Customer Support</a></li>
          </ul>
        </div>

        <div class="prototype-footer__menu">
          <h3>Warranty</h3>
          <ul>
            <li><a href="#">Warranty Information</a></li>
            <li><a href="#">Register Your Egg</a></li>
            <li><a href="#">File a Claim</a></li>
          </ul>
        </div>

        <div class="prototype-footer__menu">
          <h3>About</h3>
          <ul>
            <li><a href="#">Who We Are</a></li>
            <li><a href="#">Stories</a></li>
            <li><a href="#">Press</a></li>
            <li><a href="#">Donations</a></li>
            <li><a href="#">Careers</a></li>
          </ul>
        </div>

        <div class="prototype-footer__menu">
          <h3>Dealers</h3>
          <ul>
            <li><a href="#">Find a Dealer</a></li>
            <li><a href="#">EGGsite (Dealer Login)</a></li>
            <li><a href="#">Become-A-Dealer</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="prototype-footer__bottom">
    <div class="prototype-footer__copyright">
      © Big Green Egg 2026
    </div>

    <div class="prototype-footer__legal">
      <a href="#">Authorized Dealer &amp; Internet Policy</a>
      <a href="#">ADA Compliance</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Prototype Footer",
  "tag": "section",
  "class": "section-prototype-footer",
  "settings": [],
  "presets": [
    {
      "name": "Prototype Footer"
    }
  ]
}
{% endschema %}

