{{ 'prototype-header.css' | asset_url | stylesheet_tag }}

<div id='prototype-header' class='prototype-header'>
  <div class='prototype-header__inner prototype-header__desktop'>
    <div class='prototype-header__left'>
      <nav class='prototype-header__nav' aria-label='Primary navigation'>
        <a href='#'>Shop</a>
        <a href='#'>Learn</a>
        <a href='#'>Community</a>
        <a href='#'>Recipes</a>
      </nav>
    </div>

    <div class='prototype-header__center'>
      <a href='{{ routes.root_url }}' class='prototype-header__logo'>Big Green Egg</a>
    </div>

    <div class='prototype-header__right'>
      <a href='#' class='prototype-header__dealer-link'>Find a Dealer</a>

      <div class='prototype-header__icons'>
        <a href='#' class='prototype-header__icon' aria-label='Account'>
          <svg viewBox='0 0 24 24' aria-hidden='true'>
            <circle cx="12" cy="12" r="9"></circle>
            <circle cx="12" cy="9" r="3"></circle>
            <path d="M6.5 18c1.4-2 3.2-3 5.5-3s4.1 1 5.5 3"></path>
          </svg>
        </a>

        <a href='#' class='prototype-header__icon' aria-label='Search'>
          <svg viewBox='0 0 24 24' aria-hidden='true'>
            <circle cx="10.5" cy="10.5" r="6.5"></circle>
            <path d="M16 16l5 5"></path>
          </svg>
        </a>

        <a href='#' class='prototype-header__icon' aria-label='Cart'>
          <span class='prototype-header__cart-count'>1</span>
          <svg viewBox='0 0 24 24' aria-hidden='true'>
            <path d="M3 5h2l2.2 9h10.6L20 7H6"></path>
            <circle cx="10" cy="19" r="1.2"></circle>
            <circle cx="17" cy="19" r="1.2"></circle>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class='prototype-header__mobile'>
    <div class='prototype-header__mobile-group prototype-header__mobile-group--left'>
      <a href='#' class='prototype-header__icon' aria-label='Menu'>
        <svg viewBox='0 0 24 24' aria-hidden='true'>
          <path d="M3 6h18"></path>
          <path d="M3 12h18"></path>
          <path d="M3 18h18"></path>
        </svg>
      </a>

      <a href='#' class='prototype-header__icon' aria-label='Search'>
        <svg viewBox='0 0 24 24' aria-hidden='true'>
          <circle cx="10.5" cy="10.5" r="6.5"></circle>
          <path d="M16 16l5 5"></path>
        </svg>
      </a>
    </div>

    <a href='{{ routes.root_url }}' class='prototype-header__mobile-logo'>Big Green Egg</a>

    <div class='prototype-header__mobile-group prototype-header__mobile-group--right'>
      <a href='#' class='prototype-header__icon' aria-label='Account'>
        <svg viewBox='0 0 24 24' aria-hidden='true'>
          <circle cx="12" cy="12" r="9"></circle>
          <circle cx="12" cy="9" r="3"></circle>
          <path d="M6.5 18c1.4-2 3.2-3 5.5-3s4.1 1 5.5 3"></path>
        </svg>
      </a>

      <a href='#' class='prototype-header__icon' aria-label='Cart'>
        <span class='prototype-header__cart-count'>1</span>
        <svg viewBox='0 0 24 24' aria-hidden='true'>
          <path d="M3 5h2l2.2 9h10.6L20 7H6"></path>
          <circle cx="10" cy="19" r="1.2"></circle>
          <circle cx="17" cy="19" r="1.2"></circle>
        </svg>
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Prototype Header",
  "tag": "section",
  "class": "section-prototype-header",
  "settings": [],
  "presets": [
    {
      "name": "Prototype Header"
    }
  ]
}
{% endschema %}
