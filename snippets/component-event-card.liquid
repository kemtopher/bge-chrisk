{%- comment -%}
  Reusable event card snippet

  Example usage:
  {% render 'event-card' %}

  Later you can pass in real data like:
  {% render 'event-card',
    event_date: event.date,
    event_title: event.title,
    event_location: event.location,
    event_image: event.image,
    event_url: event.url
  %}
{%- endcomment -%}

{%- liquid
  assign card_date = event_date | default: 'Saturday, May 2, 2026 at 9:00 AM'
  assign card_title = event_title | default: 'Wayne County EGGfest'
  assign card_location = event_location | default: '11881 Dover Rd, Apple Creek, Ohio 44606'
  assign card_button_label = button_label | default: 'Get Tickets'
  assign card_url = event_url | default: '#'
-%}

<article class='event-card'>
  <div class='event-card__inner'>
    <div class='event-card__content'>
      <p class='event-card__date'>{{ card_date }}</p>

      <h3 class='event-card__title'>{{ card_title }}</h3>

      <p class='event-card__location'>{{ card_location }}</p>

      <a href='{{ card_url }}' class='event-card__button'>
        {{ card_button_label }}
      </a>
    </div>

    <div class='event-card__media'>
      {% if event_image != blank %}
        {{
          event_image
          | image_url: width: 400
          | image_tag:
            class: 'event-card__image',
            loading: 'lazy',
            widths: '160, 240, 320, 400',
            sizes: '(max-width: 749px) 96px, 120px'
        }}
      {% else %}
        <div class='event-card__image event-card__image--placeholder'>
          <span>Event Image</span>
        </div>
      {% endif %}
    </div>
  </div>
</article>
